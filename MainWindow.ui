           </property>
           <property name="styleSheet">
            <string notr="true">QPushButton {
    background: transparent; /* Nền trong suốt để lộ màu trắng của NavBar */
    border: none; /* Không có khung viền */
    font-size: 14px;
    font-family: &quot;Georgia&quot;;
    color: #4A90E2; /* Chuyển sang màu xanh dương để hợp với tông #CFE4FF */
}

QPushButton:hover {
    color: #0D3B66; /* Màu xanh đậm hơn khi di chuột qua để tạo điểm nhấn */
    text-decoration: underline; /* Hiện gạch chân khi hover giống như một liên kết */
}

QPushButton:pressed {
    color: #CFE4FF; /* Màu xanh nhạt xuất hiện khi nhấn vào */
}</string>
           </property>
           <property name="text">
            <string>Spring</string>

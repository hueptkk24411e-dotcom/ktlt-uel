      <string notr="true">/* Áp dụng trực tiếp cho chính Widget này và toàn bộ con bên trong */
QWidget {
    background-color: #FFFFFF; /* Nền trắng sạch sẽ */
    color: #000000;            /* Chữ đen rõ ràng */
    font-family: 'Georgia';
}

QLabel {

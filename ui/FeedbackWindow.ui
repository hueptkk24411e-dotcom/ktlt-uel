   <string notr="true">/* ===== NỀN CHÍNH ===== */
QWidget {
    background-color: #e6f4fa;
    color: #000000;
    font-family: 'Georgia';
}

/* ===== KHUNG CHỨA (nếu muốn bo góc nền chính) ===== */
QFrame {
    background: qlineargradient(
        spread:pad,
        x1:0, y1:0,
        x2:1, y2:1,
        stop:0 #ffffff,
        stop:0.5 #e6f4fa,
        stop:1 #d4edf7
    );
    border-radius: 20px;
}

/* ===== LABEL NỔI BẬT ===== */
QLabel {
    background: qlineargradient(
        spread:pad,
        x1:0, y1:0,
        x2:1, y2:1,
        stop:0 rgba(255,255,255,220),
        stop:1 rgba(255,255,255,150)
    );
    border-radius: 15px;
    padding: 8px 15px;
    border: 1px solid rgba(255,255,255,180);
}</string>

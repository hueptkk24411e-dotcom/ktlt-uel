     <property name="styleSheet">
      <string notr="true">QPushButton {
    
	background-color: rgb(208, 236, 250);
    color: #0D3B66;
    font-weight: bold;
    font-size: 15px;

    border: none;              /* bỏ viền mặc định */
    border-radius: 15px;       /* tăng lên để bo tròn rõ hơn */
    padding: 8px 15px;         /* tạo khoảng cách bên trong */
}

QPushButton:hover {
   
	background-color: rgb(208, 236, 250);
}

QPushButton:pressed {
    background-color: #8FB6F5; /* hiệu ứng khi bấm */
}</string>

          <property name="styleSheet">
           <string notr="true">QTableWidget {
    background-color: #e6f4fa;
    alternate-background-color: #E1EFFF;
    font-family: &quot;Georgia&quot;;
    font-size: 14px;
    gridline-color: #CFE4FF;

    border: 2px solid #A6C8FF;
    border-radius: 20px;
}

/* Header container */
QHeaderView {
    background: transparent;
}

/* Header cells */
QHeaderView::section {
    background-color: #e6f4fa;
    color: #0D3B66;
    font-weight: bold;
    font-family: &quot;Georgia&quot;;
    height: 32px;

    border: none;              /* bỏ border để không lệch */
    border-bottom: 1px solid #A6C8FF;
}

/* bo góc trái */
QHeaderView::section:first {
    border-top-left-radius: 20px;
}

/* bo góc phải */
QHeaderView::section:last {
    border-top-right-radius: 20px;
}</string>

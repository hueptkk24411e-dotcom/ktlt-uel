    font-size: 14px;
    font-weight: bold;
    font-family: &quot;Georgia&quot;;
    border: 2px solid rgb(67, 139, 196); /* Viền xanh đậm hơn một chút để tạo khối */
}

QPushButton:hover {
    background-color: #A6C8FF; /* Màu đậm hơn khi di chuột vào */
    border: 2px solid #7FAFFF; /* Viền đậm hơn khi hover */
    color: white; /* Chuyển chữ sang trắng để nổi bật */
}

QPushButton:pressed {
    background-color: #7FAFFF; /* Màu đậm nhất khi nhấn giữ nút */
    border: 2px solid #4A90E2;
}</string>
